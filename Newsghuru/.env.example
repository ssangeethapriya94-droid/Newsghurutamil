# =========================================================================
# NEWSGHURU MASTER ENVIRONMENT VARIABLES TEMPLATE (.env)
# =========================================================================
# Rename this file to '.env' in each respective subdirectory (backend/, admin/,
# users-english/, users-tamil/) and configure the variables for production.
# DO NOT commit files containing actual secrets/credentials to source control.

# =========================================================================
# 1. BACKEND SERVICE (.env inside /backend)
# =========================================================================

# Port the Express server listens on (default is 5000)
PORT=5000

# Production MongoDB Connection String
MONGO_URI=mongodb://username:password@hostname:port/databaseName?ssl=true&replicaSet=atlas-replica-set&authSource=admin&retryWrites=true&w=majority

# Default Admin Credentials (seeded on first DB setup only)
ADMIN_EMAIL=your_admin_email@gmail.com
ADMIN_PASSWORD=strong_admin_password

# JWT Authentication Secret Key
JWT_SECRET=generate_a_very_long_secure_random_key_here

# Frontend Application Portals (Used by backend to build email/FCM notification links)
FRONTEND_URL=https://newsghuru.in            # Tamil site (or English site if swapped)
FRONTEND_URL_TA=https://tamil.newsghuru.in      # Tamil portal URL
# If serving under directories instead of subdomains:
# FRONTEND_URL=https://newsghuru.in/en
# FRONTEND_URL_TA=https://newsghuru.in/ta

# Razorpay Payment Gateway Keys (Production)
RAZORPAY_KEY_ID=rzp_live_your_live_key_id
RAZORPAY_KEY_SECRET=your_live_key_secret

# SMTP Email Configuration (Used for newsletters/schedules via Gmail or SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_EMAIL=your_sending_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password      # Use Gmail App Password, not main password

# YouTube API & Channels for auto-syncing videos and shorts
YOUTUBE_API_KEY=AIzaSyYourProductionYouTubeApiKey
ENGLISH_CHANNEL_ID=UCwLcAVYQc738R4ENb_eB7-A
TAMIL_CHANNEL_ID=UC69EqPuvGnVOnsTtepUrPgg


# =========================================================================
# 2. ADMIN PORTAL (.env inside /admin)
# =========================================================================

# API backend URL that the React admin dashboard connects to
REACT_APP_API_URL=https://api.newsghuru.in

# LanguageTool API Url (for spell/grammar check)
REACT_APP_LANGUAGETOOL_API_URL=https://api.languagetool.org/v2/check


